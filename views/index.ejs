<!-- RSS Feed Scripts -->
<script>
document.addEventListener('DOMContentLoaded', async () => {
    // Load América news
    loadNews('/api/rss/america', 'america-news', 3);
    // Load Vida y Familia news
    loadNews('/api/rss/vida-familia', 'vida-familia-news', 3);
});

async function loadNews(url, containerId, limit) {
    const container = document.getElementById(containerId);
    try {
        const res = await fetch(url);
        const data = await res.json();
        if (data.items && data.items.length > 0) {
            container.innerHTML = data.items.slice(0, limit).map(item => `
                <a href="${item.link}" target="_blank" rel="noopener noreferrer" class="card bg-bg-secondary rounded-2xl overflow-hidden shadow-sm block group">
                    ${item.image ? `<div class="h-48 overflow-hidden"><img src="${item.image}" alt="${item.title}" class="w-full h-full object-cover group-hover:scale-105 transition duration-500" loading="lazy"></div>` : ''}
                    <div class="p-5">
                        <h3 class="font-serif text-lg font-bold text-primary group-hover:text-accent transition-colors line-clamp-2 mb-2">${item.title}</h3>
                        <p class="text-text-secondary text-sm line-clamp-3">${item.description}</p>
                        ${item.date ? `<p class="text-text-secondary text-xs mt-3">${new Date(item.date).toLocaleDateString('es-CR', { year: 'numeric', month: 'long', day: 'numeric' })}</p>` : ''}
                    </div>
                </a>
            `).join('');
        } else {
            container.innerHTML = '<p class="text-text-secondary text-center col-span-3">No hay noticias disponibles</p>';
        }
    } catch (error) {
        container.innerHTML = '<p class="text-text-secondary text-center col-span-3">Error al cargar noticias</p>';
    }
}
</script>