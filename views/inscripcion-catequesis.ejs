<!-- Hero Section -->
<section class="relative min-h-[40vh] py-12 flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-primary via-primary/80 to-bg-light"></div>
    <div class="relative text-center px-4 max-w-4xl">
        <span class="text-accent uppercase tracking-widest text-sm font-semibold mb-4" data-hero-animate>Catequesis Prematrimonial</span>
        <h1 class="font-serif text-4xl md:text-5xl font-black text-white leading-tight mb-4" data-hero-animate>Inscripción</h1>
        <p class="text-white/90 text-lg max-w-2xl mx-auto leading-relaxed" data-hero-animate>Complete el formulario para reservar su lugar.</p>
    </div>
</section>

<!-- Form Section -->
<section class="max-w-2xl mx-auto px-4 py-16">
    <div class="bg-bg-secondary rounded-2xl p-8 md:p-10 shadow-sm scroll-animate">
        <h2 class="font-serif text-2xl font-bold text-primary mb-2">Datos de Inscripción</h2>
        <p class="text-text-secondary text-sm mb-8">Complete sus datos y será redirigido a WhatsApp para confirmar su inscripción.</p>
        
        <form id="catequesis-form" class="space-y-5">
            <div>
                <label for="nombre" class="block text-sm font-medium text-text-primary mb-2">Nombre completo</label>
                <input type="text" id="nombre" name="nombre" required placeholder="Ej: María López" class="form-input w-full bg-white border border-primary-light/30 rounded-lg px-4 py-3 text-sm text-text-primary placeholder-text-secondary focus:outline-none" aria-required="true">
            </div>
            
            <div>
                <label for="telefono" class="block text-sm font-medium text-text-primary mb-2">Teléfono</label>
                <input type="tel" id="telefono" name="telefono" required placeholder="Ej: 8888 8888" class="form-input w-full bg-white border border-primary-light/30 rounded-lg px-4 py-3 text-sm text-text-primary placeholder-text-secondary focus:outline-none" aria-required="true">
            </div>
            
            <div>
                <label for="correo" class="block text-sm font-medium text-text-primary mb-2">Correo electrónico</label>
                <input type="email" id="correo" name="correo" required placeholder="Ej: correo@ejemplo.com" class="form-input w-full bg-white border border-primary-light/30 rounded-lg px-4 py-3 text-sm text-text-primary placeholder-text-secondary focus:outline-none" aria-required="true">
            </div>
            
            <div>
                <label for="pareja" class="block text-sm font-medium text-text-primary mb-2">Nombre de su pareja (opcional)</label>
                <input type="text" id="pareja" name="pareja" placeholder="Ej: Carlos Ramírez" class="form-input w-full bg-white border border-primary-light/30 rounded-lg px-4 py-3 text-sm text-text-primary placeholder-text-secondary focus:outline-none">
            </div>
            
            <div>
                <label for="mensaje" class="block text-sm font-medium text-text-primary mb-2">Comentarios adicionales (opcional)</label>
                <textarea id="mensaje" name="mensaje" rows="3" placeholder="Ej: Preguntas, comentarios, etc." class="form-input w-full bg-white border border-primary-light/30 rounded-lg px-4 py-3 text-sm text-text-primary placeholder-text-secondary resize-none focus:outline-none"></textarea>
            </div>
            
            <button type="submit" class="btn btn-accent w-full py-4 rounded-lg font-semibold text-sm uppercase tracking-wider">
                Enviar por WhatsApp
            </button>
            
            <p class="text-xs text-text-secondary text-center">
                Será redirigido a WhatsApp para confirmar su inscripción.
            </p>
        </form>
    </div>
</section>

<script>
document.getElementById('catequesis-form').addEventListener('submit', (e) => {
    e.preventDefault();
    
    const form = e.target;
    const nombre = form.nombre.value.trim();
    const telefono = form.telefono.value.trim();
    const correo = form.correo.value.trim();
    const pareja = form.pareja.value.trim();
    const mensaje = form.mensaje.value.trim();
    
    let text = `*Inscripción Catequesis Prematrimonial*%0A%0A`;
    text += `*Nombre:* ${encodeURIComponent(nombre)}%0A`;
    text += `*Teléfono:* ${encodeURIComponent(telefono)}%0A`;
    text += `*Correo:* ${encodeURIComponent(correo)}%0A`;
    
    if (pareja) {
        text += `*Pareja:* ${encodeURIComponent(pareja)}%0A`;
    }
    
    if (mensaje) {
        text += `*Comentarios:* ${encodeURIComponent(mensaje)}%0A`;
    }
    
    text += `%0AQuiero inscribirme a la Catequesis Prematrimonial.`;
    
    window.open(`https://wa.me/50688830657?text=${text}`, '_blank');
});
</script>