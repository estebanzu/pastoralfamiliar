<aside class="w-full lg:w-80 flex-shrink-0" aria-label="Noticias de Familias">
    <div class="sticky top-24">
        <div class="bg-bg-secondary rounded-2xl p-6 shadow-sm">
            <div class="flex items-center gap-2 mb-5">
                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                <h3 class="font-serif text-lg font-bold text-primary">Familias</h3>
            </div>
            <div id="familias-sidebar" class="space-y-4">
                <div class="flex items-center gap-3 animate-pulse">
                    <div class="w-16 h-16 rounded-lg bg-primary/10 flex-shrink-0"></div>
                    <div class="flex-1 space-y-2">
                        <div class="h-3 bg-primary/10 rounded w-3/4"></div>
                        <div class="h-3 bg-primary/10 rounded w-1/2"></div>
                    </div>
                </div>
                <div class="flex items-center gap-3 animate-pulse">
                    <div class="w-16 h-16 rounded-lg bg-primary/10 flex-shrink-0"></div>
                    <div class="flex-1 space-y-2">
                        <div class="h-3 bg-primary/10 rounded w-3/4"></div>
                        <div class="h-3 bg-primary/10 rounded w-1/2"></div>
                    </div>
                </div>
                <div class="flex items-center gap-3 animate-pulse">
                    <div class="w-16 h-16 rounded-lg bg-primary/10 flex-shrink-0"></div>
                    <div class="flex-1 space-y-2">
                        <div class="h-3 bg-primary/10 rounded w-3/4"></div>
                        <div class="h-3 bg-primary/10 rounded w-1/2"></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="mt-4 text-center">
            <a href="https://www.aciprensa.com/tags/1001/familias" target="_blank" rel="noopener noreferrer" class="text-primary text-xs font-medium hover:underline">Ver más en ACI Prensa →</a>
        </div>
    </div>
</aside>

<script>
document.addEventListener('DOMContentLoaded', async () => {
    const container = document.getElementById('familias-sidebar');
    try {
        const res = await fetch('/api/rss/familias');
        const data = await res.json();
        if (data.items && data.items.length > 0) {
            container.innerHTML = data.items.slice(0, 5).map(item => `
                <a href="${item.link}" target="_blank" rel="noopener noreferrer" class="flex gap-3 group">
                    ${item.image ? `<img src="${item.image}" alt="" class="w-16 h-16 rounded-lg object-cover flex-shrink-0 group-hover:scale-105 transition duration-300" loading="lazy">` : `<div class="w-16 h-16 rounded-lg bg-accent/10 flex items-center justify-center flex-shrink-0"><svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path></svg></div>`}
                    <div class="flex-1 min-w-0">
                        <h4 class="text-sm font-semibold text-text-primary group-hover:text-accent transition-colors line-clamp-2 leading-snug">${item.title}</h4>
                        ${item.date ? `<p class="text-xs text-text-secondary mt-1">${new Date(item.date).toLocaleDateString('es-CR', { day: 'numeric', month: 'short' })}</p>` : ''}
                    </div>
                </a>
            `).join('');
        } else {
            container.innerHTML = '<p class="text-text-secondary text-sm text-center py-4">No hay noticias disponibles</p>';
        }
    } catch (error) {
        container.innerHTML = '<p class="text-text-secondary text-sm text-center py-4">Error al cargar noticias</p>';
    }
});
</script>